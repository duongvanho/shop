<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools">

    <TextView
        android:id="@+id/tvProfileTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Your Profile"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingVertical="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/viewDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        app:layout_constraintTop_toBottomOf="@id/tvProfileTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Profile Section -->
    <LinearLayout
        android:id="@+id/llProfile"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="12dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/viewDivider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@mipmap/ic_launcher_round"
            android:background="@drawable/circle"
            android:layout_marginEnd="12dp"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvProfileName"
                android:text=""
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000"
                android:layout_height="20dp"
                android:layout_width="50dp"/>

            <TextView
                android:id="@+id/tvProfileEmail"
                android:text=""
                android:textSize="14sp"
                android:textColor="#888"
                android:layout_height="20dp"
                android:layout_width="200dp"/>

            <TextView
                android:id="@+id/tvProfilePhone"
                android:text=""
                android:textSize="14sp"
                android:textColor="#888"
                android:layout_height="20dp"
                android:layout_width="200dp"/>

            <TextView
                android:id="@+id/tvProfileAddress"
                android:text=""
                android:textSize="14sp"
                android:textColor="#888"
                android:layout_height="wrap_content"
                android:layout_width="200dp"
                android:maxLines="2"
                android:ellipsize="end"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/ivEditProfile"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="#00C281" />
    </LinearLayout>

    <View
        android:id="@+id/viewDivider2"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        app:layout_constraintTop_toBottomOf="@id/llProfile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnOrderHistory"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="Lịch sử đặt hàng"
        android:textColor="#00C281"
        android:background="#F2F3F2"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/viewDivider2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnLogOut"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="@string/log_out"
        android:textColor="#00C281"
        android:background="#F2F3F2"
        android:drawableStart="@android:drawable/ic_lock_power_off"
        android:drawablePadding="8dp"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnOrderHistory"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
